{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {},
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ]
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["node_modules", "dist", "data", "*.min.js"]
}
